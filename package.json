{
  "name": "stepcanvas",
  "private": true,
  "version": "1.0.0",
  "description": "Local-first desktop workflow documentation recorder and exporter.",
  "author": "StepCanvas Contributors",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.stepcanvas.app",
    "productName": "StepCanvas",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/uiohook-napi/**/*",
      "**/node_modules/sharp/**/*"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "dir"
      ]
    },
    "icon": "build/icon.png"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "docx": "^9.6.0",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.575.0",
    "pptxgenjs": "^4.0.1",
    "puppeteer": "^24.37.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sharp": "^0.34.5",
    "uiohook-napi": "^1.5.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.13",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^3.2.4"
  }
}
